{
    "mlp_plr_temporal":{
        "model": {
            "d_layers": ["$power_d_layers", 1, 4, 7, 11],
            "dropout": ["?uniform", 0.0, 0.0, 0.75],
            "num_embeddings": {
                "n_frequencies": ["$power_int", 1, 7],
                "frequency_scale": ["loguniform", 0.01, 100.0],
                "d_embedding": ["$power_int", 1, 5]
            },
            "implicit_time_dim": ["categorical", [0, 8, 16, 32, 64, 128]],
            "test_time_adaptation": ["categorical", [true, false]],
            "enable_bypass": ["categorical", [true, false]],
            "use_cbp": ["categorical", [true, false]],
            "replacement_rate": ["loguniform", 1e-5, 1e-3],
            "maturity_threshold": ["int", 50, 500],
            "cbp_init": ["categorical", ["kaiming", "xavier", "lecun"]],
            "drift_significance_threshold": ["loguniform", 0.01, 0.2],
            "temporal_embeddings": {
                "d_embedding": ["$power_int", 3, 7],
                "decay_factor": ["loguniform", 0.01, 0.5],
                "periodic_patterns": ["categorical", [
                    [24],
                    [24, 168],
                    [24, 168, 720],
                    [1, 3, 6, 12, 24]
                ]]
            }
        },
        "training": {
            "lr": ["loguniform", 1e-05, 0.001],
            "weight_decay": ["?loguniform", 0.0, 1e-06, 0.001]
        },
        "general":  {}
    }
}