{
    "ftt_temporal": {
        "model": {
            "token_bias": true,
            "n_layers": 1,
            "d_token": 32,
            "n_heads": 8,
            "d_ffn_factor": 1.3333333333333333,
            "attention_dropout": 0.2,
            "ffn_dropout": 0.1,
            "residual_dropout": 0.0,
            "activation": "reglu",
            "prenormalization": false,
            "initialization": "kaiming",
