            "kv_compression_sharing": null,
            "temporal_embeddings": {
                "order": [1, 1, 1, 1],
                "trend": true,
                "d_embedding": 8
            }
        },
        "training": {
            "lr": 0.0001,
            "weight_decay": 1e-05
        },
        "general": {}
    }
}